<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory
        android:title="Keyboard setup">
        <Preference
            android:key="open_ime_settings"
            android:title="Enable LightIME in Android Settings"
            android:summary="Opens Android's keyboard settings screen" />
        <Preference
            android:key="show_input_picker"
            android:title="Switch keyboard now"
            android:summary="Shows the Android keyboard picker" />
    </PreferenceCategory>

    <EditTextPreference
        android:key="dg_api_key"
        android:title="Deepgram API key"
        app:useSimpleSummaryProvider="true" />
    <EditTextPreference
        android:key="dg_language"
        android:defaultValue="en-US"
        android:title="Language" />
    <EditTextPreference
        android:key="dg_endpointing"
        android:defaultValue="300"
        android:title="Endpointing (ms)" />
    <SwitchPreferenceCompat
        android:key="dg_interim"
        android:defaultValue="true"
        android:title="Live interim preview" />
    <SwitchPreferenceCompat
        android:key="auto_cap"
        android:defaultValue="true"
        android:title="Auto capitalization" />
    <SwitchPreferenceCompat
        android:key="t9_predictive"
        android:defaultValue="true"
        android:title="Predictive T9 suggestions" />
    <SwitchPreferenceCompat
        android:key="force_hide_onscreen_t9_keypad"
        android:defaultValue="false"
        android:title="Force hide on-screen T9 keypad"
        android:summary="Hide the touch T9 keypad and action row even on touchscreen devices" />
    <ListPreference
        android:key="mic_hardware_key"
        android:defaultValue="CALL"
        android:entries="@array/mic_key_labels"
        android:entryValues="@array/mic_key_values"
        android:title="Mic hardware button" />

    <PreferenceCategory
        android:title="Hardware keypad mapping">
        <ListPreference
            android:key="keymap_backspace"
            android:defaultValue="DEL"
            android:entries="@array/keymap_key_labels_with_long_press"
            android:entryValues="@array/keymap_key_values_with_long_press"
            android:title="Backspace action key" />
        <ListPreference
            android:key="keymap_enter"
            android:defaultValue="ENTER"
            android:entries="@array/keymap_key_labels_with_long_press"
            android:entryValues="@array/keymap_key_values_with_long_press"
            android:title="Enter action key" />
        <ListPreference
            android:key="keymap_space"
            android:defaultValue="KEY_0"
            android:entries="@array/keymap_key_labels_with_long_press"
            android:entryValues="@array/keymap_key_values_with_long_press"
            android:title="Space / commit action key" />
        <ListPreference
            android:key="keymap_period"
            android:defaultValue="KEY_1"
            android:entries="@array/keymap_key_labels_with_long_press"
            android:entryValues="@array/keymap_key_values_with_long_press"
            android:title="Period action key" />
        <ListPreference
            android:key="keymap_shift"
            android:defaultValue="POUND"
            android:entries="@array/keymap_key_labels"
            android:entryValues="@array/keymap_key_values"
            android:title="Shift (ABC/abc) action key" />
        <ListPreference
            android:key="keymap_symbol"
            android:defaultValue="STAR"
            android:entries="@array/keymap_key_labels_with_long_press"
            android:entryValues="@array/keymap_key_values_with_long_press"
            android:title="Comma/symbol action key" />
    </PreferenceCategory>
    <EditTextPreference
        android:key="dg_keyterms"
        android:title="Deepgram keyterms (newline separated)"
        android:dialogMessage="One phrase per line" />
    <EditTextPreference
        android:key="text_corrections"
        android:title="Corrections (phrase&lt;TAB&gt;replacement per line)" />
    <EditTextPreference
        android:key="emoji_replacements"
        android:title="Emoji replacements (phrase&lt;TAB&gt;emoji per line)" />
    <EditTextPreference
        android:key="spelling_mode"
        android:defaultValue="1"
        android:title="Spelling mode: 0 off, 1 auto, 2 explicit, 3 both" />
</PreferenceScreen>
